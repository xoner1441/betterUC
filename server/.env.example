PORT=3000
DATA_DIR=/opt/betteruc-relay/data
MAX_CLIENTS=500
PING_TTL_MS=15000

# Existing platform secrets
TOKEN_PEPPER=replace-with-random-hex
ADMIN_KEY=replace-with-random-admin-key
ALLOW_LEGACY_TOKEN=true

# Optional Discord bot
DISCORD_BOT_TOKEN=replace-with-discord-bot-token
DISCORD_GUILD_ID=replace-with-discord-server-id
DISCORD_TICKET_CATEGORY_NAME=Tickets
DISCORD_TEAM_ROLE_NAMES=Owner,Admin,Helper
DISCORD_MOD_USER_ROLE_NAME=Mod-User
